{
  "compilerOptions": {
    // Environment setup & latest features
    // wobbly is a browser library: Worker, Blob, navigator, AbortSignal, and
    // MessageEvent all come from DOM. bun-types defers to lib.dom when it is
    // present and falls back to stubs when it isn't (see UseLibDomIfAvailable),
    // so without this AbortController typechecks as an empty object.
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
